---
// 閱讀進度條 — D 混搭版：掃描游標 + 細離散刻度，已讀刻度整條綠→粉漸變
// 桌機：右側垂直；手機：底部橫向半透明。純裝飾，隨頁面捲動更新。
---
<div class="reading-progress" aria-hidden="true">
  <div class="rp-vert">
    <div class="rp-ticks rp-ticks-v"></div>
    <div class="rp-cur rp-cur-v"><span class="rp-dot"></span><span class="rp-lbl mono">0%</span></div>
  </div>
  <div class="rp-horiz">
    <div class="rp-ticks rp-ticks-h"></div>
    <span class="rp-cur-h"></span>
  </div>
</div>

<style>
  .reading-progress { pointer-events: none; }

  /* ---- 桌機：右側垂直 ---- */
  .rp-vert {
    position: fixed; right: 22px; top: 50%; transform: translateY(-50%);
    height: 56vh; width: 30px; z-index: 30;
  }
  .rp-ticks-v { position: absolute; right: 0; top: 0; bottom: 0; display: flex; flex-direction: column; justify-content: space-between; align-items: flex-end; }
  .rp-ticks-v i { display: block; width: 10px; height: 2px; background: var(--line); border-radius: 2px; }
  .rp-ticks-v i.on { width: 12px; }
  .rp-cur-v { position: absolute; right: 0; top: 0%; transform: translateY(-50%); display: flex; align-items: center; gap: 8px; flex-direction: row-reverse; }
  .rp-cur-v .rp-dot { width: 11px; height: 11px; border-radius: 50%; background: var(--pink); box-shadow: 0 0 9px rgba(255,168,197,1), 0 0 20px rgba(255,168,197,.5); }
  .rp-lbl { font-size: 10px; color: var(--aqua); letter-spacing: .05em; font-variant-numeric: tabular-nums; }

  /* ---- 手機：底部橫向半透明 ---- */
  .rp-horiz {
    display: none;
    position: fixed; left: 0; right: 0; bottom: 0; height: 16px; z-index: 30;
    background: rgba(15,27,30,.55); backdrop-filter: blur(4px);
  }
  .rp-ticks-h { position: absolute; left: 10px; right: 10px; bottom: 4px; display: flex; justify-content: space-between; align-items: flex-end; }
  .rp-ticks-h i { display: block; width: 2px; height: 7px; background: var(--line); border-radius: 2px; }
  .rp-ticks-h i.on { height: 9px; }
  .rp-cur-h { position: absolute; bottom: 2px; left: 0%; transform: translateX(-50%); width: 9px; height: 9px; border-radius: 50%; background: var(--pink); box-shadow: 0 0 8px rgba(255,168,197,1); }

  @media (max-width: 900px) {
    .rp-vert { display: none; }
    .rp-horiz { display: block; }
  }
  @media (prefers-reduced-motion: no-preference) {
    .rp-ticks i { transition: background .12s, box-shadow .12s, width .12s, height .12s; }
  }
</style>

<script>
  const AQUA = [62, 230, 201], PINK = [255, 168, 197];
  const lerp = (t: number) =>
    `rgb(${Math.round(AQUA[0] + (PINK[0] - AQUA[0]) * t)},${Math.round(AQUA[1] + (PINK[1] - AQUA[1]) * t)},${Math.round(AQUA[2] + (PINK[2] - AQUA[2]) * t)})`;

  function setup(container: Element | null, count: number) {
    if (!container) return { items: [] as HTMLElement[], colors: [] as string[] };
    const colors: string[] = [];
    const items: HTMLElement[] = [];
    for (let i = 0; i < count; i++) {
      colors.push(lerp(count > 1 ? i / (count - 1) : 0));
      const el = document.createElement("i");
      container.appendChild(el);
      items.push(el);
    }
    return { items, colors };
  }

  const VT = 40, HT = 46;
  const v = setup(document.querySelector(".rp-ticks-v"), VT);
  const h = setup(document.querySelector(".rp-ticks-h"), HT);
  const curV = document.querySelector<HTMLElement>(".rp-cur-v");
  const curH = document.querySelector<HTMLElement>(".rp-cur-h");
  const lbl = document.querySelector<HTMLElement>(".rp-lbl");

  function paint(items: HTMLElement[], colors: string[], p: number) {
    const on = Math.round(p * items.length);
    items.forEach((it, i) => {
      if (i < on) {
        it.style.background = colors[i];
        it.style.boxShadow = `0 0 5px ${colors[i]}`;
        it.classList.add("on");
      } else {
        it.style.background = "";
        it.style.boxShadow = "";
        it.classList.remove("on");
      }
    });
  }

  let ticking = false;
  function update() {
    const doc = document.documentElement;
    const max = doc.scrollHeight - doc.clientHeight;
    const p = max > 0 ? Math.min(1, Math.max(0, doc.scrollTop / max)) : 0;
    paint(v.items, v.colors, p);
    paint(h.items, h.colors, p);
    if (curV) curV.style.top = p * 100 + "%";
    if (curH) curH.style.left = p * 100 + "%";
    if (lbl) lbl.textContent = Math.round(p * 100) + "%";
    ticking = false;
  }
  function onScroll() {
    if (!ticking) { ticking = true; requestAnimationFrame(update); }
  }
  window.addEventListener("scroll", onScroll, { passive: true });
  window.addEventListener("resize", onScroll);
  update();
</script>
